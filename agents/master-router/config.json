{
  "agentName": "master-router",
  "description": "Routes incoming requests to the appropriate channel agent based on task classification, trigger evaluation, and enhancement pipeline",
  "capabilities": ["routing", "prompt-enhancement", "trigger-evaluation", "channel-assignment", "multi-stage-orchestration"],
  "channels": [
    "AgentBuilder",
    "PromptDesign",
    "ReasoningDesign",
    "SkillBuilder",
    "ToolBuilder",
    "WorkflowDesign",
    "MemoryDesign",
    "ContextBuilder",
    "TestingDesign",
    "SafetyDesign"
  ],
  "inputSchema": {
    "prompt": "string",
    "triggerContext": "object"
  },
  "outputSchema": {
    "primaryChannel": "string",
    "secondaryChannels": "array",
    "triggerActivated": "string",
    "enhancedPrompt": "string",
    "routingRationale": "string"
  }
}
